<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer diffuse glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#14FFA726" />
        </shape>
    </item>
    <!-- Mid glow ring -->
    <item
        android:left="18dp"
        android:top="18dp"
        android:right="18dp"
        android:bottom="18dp">
        <shape android:shape="oval">
            <solid android:color="#28FFA726" />
        </shape>
    </item>
    <!-- Inner warm halo -->
    <item
        android:left="36dp"
        android:top="36dp"
        android:right="36dp"
        android:bottom="36dp">
        <shape android:shape="oval">
            <solid android:color="#3DFFA726" />
        </shape>
    </item>
</layer-list>
