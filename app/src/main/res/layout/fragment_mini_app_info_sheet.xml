<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <!-- Header with close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/mini_app_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mini App"
            android:textColor="?attr/pickerTextPrimary"
            android:textStyle="bold"
            android:textSize="20sp" />

        <ImageView
            android:id="@+id/mini_app_close_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:tint="?attr/pickerTextSecondary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Description -->
    <TextView
        android:id="@+id/mini_app_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="?attr/pickerTextSecondary"
        android:textSize="14sp"
        android:maxLines="5"
        android:ellipsize="none"
        android:layout_marginBottom="16dp" />

    <!-- Coming Soon Badge and Text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp"
        android:padding="12dp"
        android:background="@drawable/bg_coming_soon_badge"
        android:backgroundTint="#33FF9500">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀"
            android:textSize="18sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/mini_app_coming_soon_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Soon"
            android:textColor="?attr/pickerTextPrimary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Features Section Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Key Features"
        android:textColor="?attr/colorHeading"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <!-- Features Container -->
    <LinearLayout
        android:id="@+id/mini_app_features_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp" />

    <!-- Info Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/settings_group_card_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:fontFamily="@font/materialicons"
                android:text="info"
                android:textColor="?attr/pickerTextSecondary"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stay tuned for updates"
                android:textColor="?attr/pickerTextPrimary"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Follow us on Discord for the latest news and feature releases."
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:layout_marginStart="36dp" />

    </LinearLayout>

</LinearLayout>
